    "jszip": "^3.10.1",
    "typescript": "^5.9.3"
  },
  "optionalDependencies": {
    "@nonth/pcsclite": "^0.6.2"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.7",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
